# Anthropic API key — used SERVER-SIDE only via /api/news
# Do NOT prefix with VITE_ (that would expose it in the browser bundle)
# Add in Vercel: Project Settings → Environment Variables
ANTHROPIC_API_KEY=your_anthropic_key_here

# Resend API key — for the contact form email delivery
# Sign up free at https://resend.com → API Keys → Create API Key
RESEND_API_KEY=your_resend_key_here

# Your private email address — where contact form messages land
# Never exposed to the browser. Server-side only.
CONTACT_EMAIL=your@email.com

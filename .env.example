# ── Anthropic (news feed) ─────────────────────────────────────────────────────
# Server-side only. Do NOT prefix with VITE_
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Gmail SMTP (contact form) ─────────────────────────────────────────────────
# Your Gmail address
GMAIL_USER=you@gmail.com

# A Google App Password — NOT your normal Gmail password.
# How to get one: myaccount.google.com → Security → 2-Step Verification → App passwords
# Generate one named e.g. "anaken-site", copy the 16-char code
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# The inbox where contact form messages land (can be same as GMAIL_USER)
CONTACT_EMAIL=you@gmail.com
